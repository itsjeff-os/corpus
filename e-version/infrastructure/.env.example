# Personal Context Engine — Environment Variables
# 
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# All required variables are marked with (REQUIRED).

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=pce
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD          # (REQUIRED)
POSTGRES_DB=pce

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD              # (REQUIRED)

# ─── Object Store (MinIO) ─────────────────────────────────────────
MINIO_ROOT_USER=pce
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD         # (REQUIRED)

# ─── Search (Meilisearch) ─────────────────────────────────────────
MEILI_MASTER_KEY=CHANGE_ME_MEILI_KEY                 # (REQUIRED)

# ─── Auth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_JWT_SECRET                      # (REQUIRED)

# ─── LLM Providers ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                                # (REQUIRED)
# ANTHROPIC_API_KEY=                                 # Optional
# COHERE_API_KEY=                                    # Optional
